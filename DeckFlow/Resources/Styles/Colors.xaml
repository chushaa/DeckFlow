<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

	<!-- Primary action colors (teal-blue from branding gradient) -->
	<Color x:Key="PrimaryLight">#2D8A96</Color>
	<Color x:Key="PrimaryDark">#48B4C8</Color>
	<Color x:Key="SecondaryLight">#388296</Color>
	<Color x:Key="SecondaryDark">#5ABFCF</Color>

	<!-- Surface & background -->
	<Color x:Key="SurfaceLight">#FFFFFF</Color>
	<Color x:Key="SurfaceDark">#1E1E1E</Color>
	<Color x:Key="BackgroundLight">#F5F5F5</Color>
	<Color x:Key="BackgroundDark">#121212</Color>

	<!-- Navigation bar -->
	<Color x:Key="NavBarLight">#4A94B0</Color>
	<Color x:Key="NavBarDark">#0F172A</Color>

	<!-- Text on colored backgrounds -->
	<Color x:Key="OnPrimaryLight">#FFFFFF</Color>
	<Color x:Key="OnPrimaryDark">#FFFFFF</Color>
	<Color x:Key="OnSurfaceLight">#1C1B1F</Color>
	<Color x:Key="OnSurfaceDark">#E6E1E5</Color>
	<Color x:Key="OnBackgroundLight">#1C1B1F</Color>
	<Color x:Key="OnBackgroundDark">#E6E1E5</Color>

	<!-- Secondary text -->
	<Color x:Key="OnSurfaceVariantLight">#6B7280</Color>
	<Color x:Key="OnSurfaceVariantDark">#9CA3AF</Color>

	<!-- Error / missing cards -->
	<Color x:Key="ErrorLight">#DC2626</Color>
	<Color x:Key="ErrorDark">#F87171</Color>
	<Color x:Key="OnErrorLight">#FFFFFF</Color>
	<Color x:Key="OnErrorDark">#121212</Color>
	<Color x:Key="ErrorContainerLight">#FEE2E2</Color>
	<Color x:Key="ErrorContainerDark">#3B1111</Color>

	<!-- Card & badge backgrounds (teal-tinted) -->
	<Color x:Key="CardBackgroundLight">#FFFFFF</Color>
	<Color x:Key="CardBackgroundDark">#2A2A2A</Color>
	<Color x:Key="BadgeBackgroundLight">#E0F5F8</Color>
	<Color x:Key="BadgeBackgroundDark">#1A3A4A</Color>
	<Color x:Key="BadgeTextLight">#1A7A8C</Color>
	<Color x:Key="BadgeTextDark">#7DD3E8</Color>

	<!-- Outline / divider -->
	<Color x:Key="OutlineLight">#E5E7EB</Color>
	<Color x:Key="OutlineDark">#374151</Color>

	<!-- Disabled -->
	<Color x:Key="DisabledLight">#D1D5DB</Color>
	<Color x:Key="DisabledDark">#4B5563</Color>
	<Color x:Key="DisabledTextLight">#9CA3AF</Color>
	<Color x:Key="DisabledTextDark">#6B7280</Color>
</ResourceDictionary>