<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:vm="clr-namespace:DeckFlow.ViewModels"
			 x:Class="DeckFlow.Views.ImportDeckPage"
			 x:DataType="vm:ImportDeckViewModel"
			 Title="Import Deck">

	<ContentPage.ToolbarItems>
		<ToolbarItem Text="Home"
					 IconImageSource="home_icon"
					 Clicked="OnHomeClicked" />
	</ContentPage.ToolbarItems>

	<Grid>

		<ScrollView>
			<VerticalStackLayout Padding="24" Spacing="20" MaximumWidthRequest="500">

				<Label Text="Import Deck List"
					   Style="{StaticResource Headline}"
					   SemanticProperties.HeadingLevel="Level1" />

				<Label Text="Select a text file containing your deck list. Format: quantity followed by card name."
					   Style="{StaticResource SubHeadline}" />

				<!-- File picker -->
				<Button Text="Select Deck File"
						Style="{StaticResource SecondaryButtonStyle}"
						Command="{Binding PickFileCommand}"
						HorizontalOptions="Fill"
						SemanticProperties.Hint="Opens file picker to select a deck list text file" />

				<!-- Selected file name -->
				<Label Text="{Binding FileName}"
					   IsVisible="{Binding FileName, Converter={StaticResource IsNotNullOrEmptyConverter}}"
					   FontFamily="InterBold"
					   HorizontalTextAlignment="Center" />

				<!-- Deck name entry -->
				<VerticalStackLayout Spacing="4" IsVisible="{Binding HasPreview}">
					<Label Text="Deck Name" FontFamily="InterBold" />
					<Entry Text="{Binding DeckName}"
						   Placeholder="Enter deck name"
						   SemanticProperties.Description="Deck name" />
				</VerticalStackLayout>

				<!-- Location binding -->
				<VerticalStackLayout Spacing="4" IsVisible="{Binding HasPreview}">
					<Label Text="Storage Location" FontFamily="InterBold" />
					<Label Text="Where is this deck physically stored?"
						   Style="{StaticResource SubHeadline}"
						   FontSize="12" />
					<Picker ItemsSource="{Binding Locations}"
							SelectedItem="{Binding SelectedLocation}"
							Title="Select location"
							SemanticProperties.Description="Deck storage location" />
				</VerticalStackLayout>

				<!-- Preview card -->
				<Border Style="{StaticResource CardStyle}"
						IsVisible="{Binding HasPreview}">
					<VerticalStackLayout Spacing="8">
						<Label Text="Preview" Style="{StaticResource SectionHeader}" />
						<HorizontalStackLayout Spacing="16">
							<VerticalStackLayout>
								<Label Text="{Binding PreviewCardCount}"
									   FontFamily="InterBold"
									   FontSize="24"
									   HorizontalTextAlignment="Center" />
								<Label Text="Total Cards"
									   Style="{StaticResource SubHeadline}"
									   FontSize="12" />
							</VerticalStackLayout>
							<VerticalStackLayout>
								<Label Text="{Binding PreviewUniqueCount}"
									   FontFamily="InterBold"
									   FontSize="24"
									   HorizontalTextAlignment="Center" />
								<Label Text="Unique"
									   Style="{StaticResource SubHeadline}"
									   FontSize="12" />
							</VerticalStackLayout>
						</HorizontalStackLayout>
					</VerticalStackLayout>
				</Border>

				<!-- Create deck button -->
				<Button Text="Create Deck"
						Style="{StaticResource PrimaryButtonStyle}"
						Command="{Binding CreateDeckCommand}"
						IsVisible="{Binding HasPreview}"
						IsEnabled="{Binding IsImporting, Converter={StaticResource InvertedBoolConverter}}"
						HorizontalOptions="Fill" />

				<!-- Status message (errors only) -->
				<Label Text="{Binding StatusMessage}"
					   IsVisible="{Binding IsError}"
					   Style="{StaticResource MissingCardStyle}"
					   HorizontalTextAlignment="Center" />

			</VerticalStackLayout>
		</ScrollView>

		<!-- Creating deck overlay -->
		<Grid IsVisible="{Binding IsImporting}"
			  InputTransparent="False">
			<BoxView Color="{AppThemeBinding Light=#80FFFFFF, Dark=#80000000}" />
			<Border StrokeShape="RoundRectangle 16"
					StrokeThickness="0"
					BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
					Opacity="0.95"
					Padding="32,24"
					HorizontalOptions="Center"
					VerticalOptions="Center">
				<VerticalStackLayout Spacing="16"
									 HorizontalOptions="Center">
					<ActivityIndicator IsRunning="{Binding IsImporting}"
									   HorizontalOptions="Center" />
					<Label Text="Creating deck..."
						   FontFamily="InterBold"
						   HorizontalTextAlignment="Center" />
				</VerticalStackLayout>
			</Border>
		</Grid>

	</Grid>

</ContentPage>