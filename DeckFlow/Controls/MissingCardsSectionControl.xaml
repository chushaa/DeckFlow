<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:contracts="clr-namespace:DeckFlow.Core.Planning.Contracts;assembly=DeckFlow.Core"
			 x:Class="DeckFlow.Controls.MissingCardsSectionControl"
			 x:DataType="contracts:MissingCardSection">

	<Border BackgroundColor="{AppThemeBinding Light={StaticResource ErrorContainerLight}, Dark={StaticResource ErrorContainerDark}}"
			StrokeThickness="1"
			Stroke="{AppThemeBinding Light={StaticResource ErrorLight}, Dark={StaticResource ErrorDark}}"
			Padding="0"
			Margin="0,0,0,8">
		<Border.StrokeShape>
			<RoundRectangle CornerRadius="12" />
		</Border.StrokeShape>
		<VerticalStackLayout>

			<!-- Error header -->
			<Grid Padding="16,12"
				  ColumnDefinitions="Auto,*"
				  ColumnSpacing="8">
				<Label Grid.Column="0"
					   Text="&#x26A0;"
					   FontSize="18"
					   VerticalOptions="Center"
					   SemanticProperties.Description="Warning" />
				<Label Grid.Column="1"
					   Text="Missing Cards"
					   Style="{StaticResource MissingCardStyle}"
					   FontFamily="InterBold"
					   FontSize="15"
					   VerticalOptions="Center" />
			</Grid>

			<!-- Missing card lines -->
			<VerticalStackLayout BindableLayout.ItemsSource="{Binding Cards}"
								 Padding="8,0,8,8">
				<BindableLayout.ItemTemplate>
					<DataTemplate x:DataType="contracts:MissingCardLine">
						<Grid ColumnDefinitions="Auto,*"
							  ColumnSpacing="8"
							  Padding="8,4">
							<Label Grid.Column="0"
								   Text="{Binding QuantityNeeded, StringFormat='{0}x'}"
								   Style="{StaticResource MissingCardStyle}"
								   FontFamily="InterBold"
								   MinimumWidthRequest="28"
								   HorizontalTextAlignment="Center"
								   VerticalOptions="Center" />
							<Label Grid.Column="1"
								   Text="{Binding Card.Name}"
								   Style="{StaticResource MissingCardStyle}"
								   LineBreakMode="TailTruncation"
								   VerticalOptions="Center" />
						</Grid>
					</DataTemplate>
				</BindableLayout.ItemTemplate>
			</VerticalStackLayout>

		</VerticalStackLayout>
	</Border>

</ContentView>