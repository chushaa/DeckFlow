<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:contracts="clr-namespace:DeckFlow.Core.Planning.Contracts;assembly=DeckFlow.Core"
			 x:Class="DeckFlow.Controls.MoveLineControl"
			 x:DataType="contracts:MoveLine">

	<Grid ColumnDefinitions="Auto,*"
		  ColumnSpacing="8"
		  Padding="8,6">

		<!-- Quantity badge -->
		<Border Grid.Column="0"
				Style="{StaticResource BadgeStyle}"
				Padding="6,2"
				MinimumWidthRequest="28"
				VerticalOptions="Center">
			<Label Text="{Binding Quantity, StringFormat='{0}x'}"
				   Style="{StaticResource BadgeTextStyle}" />
		</Border>

		<!-- Card info -->
		<VerticalStackLayout Grid.Column="1"
							 VerticalOptions="Center"
							 Spacing="1">
			<HorizontalStackLayout Spacing="6">
				<Label Text="{Binding Card.Name}"
					   FontSize="14"
					   LineBreakMode="TailTruncation" />
				<!-- Foil indicator -->
				<Label Text="Foil"
					   FontFamily="InterItalic"
					   FontSize="11"
					   TextColor="{AppThemeBinding Light={StaticResource SecondaryLight}, Dark={StaticResource SecondaryDark}}"
					   IsVisible="{Binding ActualPrinting.IsFoil}"
					   VerticalOptions="Center" />
			</HorizontalStackLayout>
			<!-- Set code -->
			<Label Text="{Binding ActualPrinting.SetCode, StringFormat='Set: {0}'}"
				   IsVisible="{Binding ActualPrinting.SetCode, Converter={StaticResource IsNotNullOrEmptyConverter}}"
				   FontSize="11"
				   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariantLight}, Dark={StaticResource OnSurfaceVariantDark}}" />
		</VerticalStackLayout>

	</Grid>

</ContentView>